<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #228B22;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.blackjackfinalproject.RunGame">
   <children>
      <VBox prefHeight="400.0" prefWidth="601.0">
         <children>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0">
               <children>
                  <HBox prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label prefHeight="30.0" prefWidth="64.0" text="Value:" textFill="WHITE">
                           <font>
                              <Font size="21.0" />
                           </font>
                        </Label>
                        <Label fx:id="dealersValue" prefHeight="30.0" prefWidth="161.0" textFill="WHITE">
                           <font>
                              <Font size="21.0" />
                           </font>
                        </Label>
                        <Label prefHeight="30.0" prefWidth="153.0" text="Dealers Hand" textFill="WHITE">
                           <font>
                              <Font size="21.0" />
                           </font>
                        </Label>
                        <Label prefHeight="30.0" prefWidth="79.0" text="Winner:" textFill="WHITE">
                           <font>
                              <Font size="21.0" />
                           </font>
                        </Label>
                        <Label fx:id="winnerText" prefHeight="30.0" prefWidth="168.0" textFill="WHITE">
                           <font>
                              <Font size="16.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <HBox fx:id="dealerBox" alignment="CENTER" prefHeight="212.0" prefWidth="601.0" />
               </children>
            </VBox>
            <VBox alignment="TOP_CENTER" prefHeight="223.0" prefWidth="601.0">
               <children>
                  <HBox prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label prefHeight="29.0" prefWidth="58.0" text="Value:" textFill="WHITE">
                           <font>
                              <Font size="21.0" />
                           </font>
                        </Label>
                        <Label fx:id="playerValue" prefHeight="29.0" prefWidth="157.0" textFill="WHITE">
                           <font>
                              <Font size="21.0" />
                           </font>
                        </Label>
                        <Label prefHeight="27.0" prefWidth="131.0" text="Player(s) Hand" textAlignment="CENTER" textFill="WHITE">
                           <font>
                              <Font size="21.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <HBox fx:id="playerBox" alignment="CENTER" prefHeight="237.0" prefWidth="601.0" />
               </children>
            </VBox>
            <HBox alignment="BOTTOM_CENTER" prefHeight="61.0" prefWidth="601.0">
               <children>
                  <Button fx:id="aceToEleven" mnemonicParsing="false" onAction="#onAceToElevenClick" text="11" />
                  <Label prefHeight="17.0" prefWidth="18.0" textFill="#f2f2f2" />
                  <Button fx:id="aceToOne" mnemonicParsing="false" onAction="#onAceToOneClick" text="1" />
                  <Label prefHeight="17.0" prefWidth="33.0" />
                  <Button fx:id="hitButton" mnemonicParsing="false" onAction="#onHitButtonClick" text="Hit" />
                  <Label text="                " />
                  <Button fx:id="standButton" mnemonicParsing="false" onAction="#onStandButtonClick" text="Stand" />
                  <Label text="                 " />
                  <Button fx:id="dealButton" mnemonicParsing="false" onAction="#onDealButtonClick" text="Deal Cards" />
                  <Label text="                " />
                  <Button fx:id="splitButton" mnemonicParsing="false" text="Split" />
                  <Label prefHeight="17.0" prefWidth="65.0" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
