<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #228B22;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.blackjackfinalproject.GameController">
   <children>
      <VBox prefHeight="400.0" prefWidth="601.0">
         <children>
            <HBox alignment="TOP_CENTER" prefHeight="148.0" prefWidth="601.0">
               <children>
                  <Label prefHeight="27.0" prefWidth="124.0" text="Dealers Hand" textFill="WHITE">
                     <font>
                        <Font size="21.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox alignment="TOP_CENTER" prefHeight="191.0" prefWidth="601.0">
               <children>
                  <Label text="Player(s) Hand" textFill="WHITE">
                     <font>
                        <Font size="21.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox alignment="BOTTOM_CENTER" prefHeight="61.0" prefWidth="601.0">
               <children>
                  <Button fx:id="hitButton" mnemonicParsing="false" text="Hit" />
                  <Label text="                " />
                  <Button fx:id="standButton" mnemonicParsing="false" text="Stand" />
                  <Label text="                 " />
                  <Button fx:id="dealButton" mnemonicParsing="false" text="Deal Cards" />
                  <Label text="                " />
                  <Button fx:id="splitButton" mnemonicParsing="false" text="Split" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
